<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scoreboard.app.controller.PausedGameController">
   <children>
      <Button layoutX="30.0" layoutY="351.0" mnemonicParsing="false" onAction="#backToHome" text="Back to Home" />
      <Button layoutX="482.0" layoutY="351.0" mnemonicParsing="false" onAction="#resumeGame" text="Resume Game" />
      <Label fx:id="groupNameLabel" layoutX="169.0" layoutY="96.0" prefHeight="45.0" prefWidth="268.0" text="Label">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <HBox layoutX="169.0" layoutY="151.0" prefHeight="179.0" prefWidth="307.0">
         <children>
            <VBox fx:id="playerNamesVBox" prefHeight="212.0" prefWidth="173.0" spacing="15">
               <children>
                  <Label fx:id="playerColum" text="Players">
                     <font>
                        <Font size="10.0" />
                     </font></Label>
                  <Label fx:id="player1" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="player2" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="player3" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="player4" prefHeight="17.0" prefWidth="175.0" />
               </children></VBox>
            <VBox fx:id="scorsVBox" prefHeight="179.0" prefWidth="96.0" spacing="15">
               <children>
                   <Label fx:id="scoreColum" text="Scores">
                       <font>
                           <Font size="10.0" />
                       </font></Label>
                  <Label fx:id="score1" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="score2" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="score3" prefHeight="17.0" prefWidth="175.0" />
                  <Label fx:id="score4" prefHeight="17.0" prefWidth="175.0" />
               </children></VBox>
         </children>
      </HBox>
      <Label layoutX="199.0" layoutY="31.0" text="Paused Game Status">
         <font>
            <Font size="22.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
