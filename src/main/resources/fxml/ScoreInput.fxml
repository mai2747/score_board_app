<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scoreboard.app.controller.ScoreInputController">
   <children>
      <Button fx:id="submitButton" defaultButton="true" layoutX="274.0" layoutY="254.0" mnemonicParsing="false" onAction="#submitScore" text="Submit" />
      <TextField fx:id="scoreField" layoutX="226.0" layoutY="200.0" promptText="Input your score" />
      <Label fx:id="playerNameLabel" alignment="CENTER" layoutX="128.0" layoutY="133.0" prefHeight="39.0" prefWidth="345.0" textAlignment="CENTER">
         <font>
            <Font size="27.0" />
         </font></Label>
      <Button layoutX="510.0" layoutY="339.0" mnemonicParsing="false" onAction="#endGame" text="End Game" />
      <Label fx:id="errorLabel" alignment="CENTER" layoutX="123.0" layoutY="225.0" prefHeight="17.0" prefWidth="356.0" textAlignment="CENTER" textFill="#e25858" />
      <Pane fx:id="prevScorePane" layoutX="29.0" layoutY="237.0" prefHeight="141.0" prefWidth="170.0">
         <children>
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#1f93ff00" height="152.0" layoutX="-1.0" stroke="#dadada" strokeType="INSIDE" strokeWidth="5.0" width="170.0" />
            <Button fx:id="editScoreButton" layoutX="42.0" layoutY="113.0" mnemonicParsing="false" onAction="#editScore" prefHeight="25.0" prefWidth="84.0" text="Edit previous score">
               <font>
                  <Font size="8.0" />
               </font>
            </Button>
            <TextField fx:id="prevScoreField" layoutX="42.0" layoutY="63.0" prefHeight="25.0" prefWidth="84.0" />
            <Label fx:id="prevPlayerLabel" alignment="CENTER" layoutX="-1.0" layoutY="28.0" prefHeight="17.0" prefWidth="173.0" textAlignment="CENTER" />
            <Label layoutX="46.0" layoutY="6.0" text="Previous score" />
            <Label fx:id="infoLabel" layoutX="7.0" layoutY="88.0" prefHeight="17.0" prefWidth="155.0" textFill="#c10000" />
         </children>
      </Pane>
   </children>
</AnchorPane>
