<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scoreboard.app.controller.PlayerStatsViewController">
   <children>
      <LineChart fx:id="statsChart" layoutX="127.0" layoutY="51.0" prefHeight="286.0" prefWidth="405.0">
        <xAxis>
          <NumberAxis prefHeight="17.0" prefWidth="404.0" side="BOTTOM" fx:id="xAxis" />
        </xAxis>
        <yAxis>
          <NumberAxis fx:id="yAxis" prefHeight="239.0" prefWidth="34.0" side="LEFT" />
        </yAxis>
      </LineChart>
      <VBox fx:id="playerCheckBoxContainer" layoutX="21.0" layoutY="94.0" prefHeight="135.0" prefWidth="100.0" spacing="20">
         <children>
            <CheckBox fx:id="playerCheckBox1" mnemonicParsing="false" text="CheckBox" />
            <CheckBox fx:id="playerCheckBox2" mnemonicParsing="false" text="CheckBox" />
            <CheckBox mnemonicParsing="false" text="CheckBox" />
            <CheckBox mnemonicParsing="false" text="CheckBox" />
         </children></VBox>
      <Button layoutX="21.0" layoutY="355.0" mnemonicParsing="false" onAction="#backToGroupHistory" text="Back to Group History" />
      <VBox fx:id="toggleButtonContainer" layoutX="21.0" layoutY="252.0" prefHeight="55.0" prefWidth="100.0" spacing="10">
         <children>
            <RadioButton fx:id="scoreRadioButton" mnemonicParsing="false" text="Total Score" />
            <RadioButton fx:id="rankingRadioButton" mnemonicParsing="false" text="Ranking" />
         </children>
      </VBox>
   </children>
</AnchorPane>
